<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="g1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0D1B2A"/>
      <stop offset="100%" style="stop-color:#0E7C7B"/>
    </linearGradient>
  </defs>
  <rect width="800" height="400" fill="url(#g1)"/>
  <rect x="60" y="60" width="200" height="120" rx="12" fill="rgba(255,255,255,.08)"/>
  <rect x="60" y="200" width="200" height="140" rx="12" fill="rgba(14,124,123,.3)"/>
  <rect x="280" y="60" width="460" height="280" rx="12" fill="rgba(255,255,255,.06)"/>
  <rect x="300" y="90" width="180" height="12" rx="6" fill="rgba(255,255,255,.3)"/>
  <rect x="300" y="115" width="120" height="8" rx="4" fill="rgba(255,255,255,.15)"/>
  <rect x="300" y="150" width="400" height="140" rx="8" fill="rgba(14,124,123,.2)"/>
  <!-- Bar chart bars -->
  <rect x="320" y="230" width="40" height="40" rx="4" fill="#0E7C7B" opacity=".8"/>
  <rect x="375" y="200" width="40" height="70" rx="4" fill="#14A5A4" opacity=".8"/>
  <rect x="430" y="215" width="40" height="55" rx="4" fill="#0E7C7B" opacity=".8"/>
  <rect x="485" y="190" width="40" height="80" rx="4" fill="#F0A500" opacity=".8"/>
  <rect x="540" y="220" width="40" height="50" rx="4" fill="#14A5A4" opacity=".8"/>
  <text x="400" y="360" font-family="sans-serif" font-size="14" fill="rgba(255,255,255,.4)"
        text-anchor="middle">Sample Dashboard Preview</text>
</svg>
