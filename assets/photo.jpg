<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0D1B2A"/>
      <stop offset="100%" style="stop-color:#1a3a5c"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0E7C7B"/>
      <stop offset="100%" style="stop-color:#14A5A4"/>
    </linearGradient>
    <clipPath id="circle"><circle cx="200" cy="200" r="200"/></clipPath>
  </defs>
  <circle cx="200" cy="200" r="200" fill="url(#bg)"/>
  <!-- Body -->
  <ellipse cx="200" cy="310" rx="90" ry="60" fill="url(#accent)" opacity=".5"/>
  <!-- Head -->
  <circle cx="200" cy="165" r="70" fill="url(#accent)" opacity=".7"/>
  <!-- Initials -->
  <text x="200" y="185" font-family="'Syne',sans-serif" font-size="52" font-weight="800"
        fill="white" text-anchor="middle" dominant-baseline="middle" opacity=".9">YD</text>
</svg>
